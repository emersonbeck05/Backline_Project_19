from datetime import datetime, timedelta

class Item:
  def __init__(self, item_id, name, stock):
    self.item_id = item_id
    self.name = name
    self.stock = stock
    self.available = stock

def rent_item(self):
  if (self.available > 0):
    self.available -= 1
    return True
  return False

def return_item(self):
  if (self.available < self.stock):
    self.available += 1
    
