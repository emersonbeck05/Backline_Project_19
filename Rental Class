# Rental Class
class Rental:
  def __init__(self, item, rentDate=None, rentalLength=7):
    self.item = item
    self.rentDate = rentDate or datetime.now()
    self.rentalLength = rentalLength

# Date of return
# Returns the date a rental is due
def returnDate(self):
  return (self.rentDate + timedelta(days=self.rentalLength))

# Days rented
# Returns number of days an item has been rented for
def daysRented(self)
  return ((datetime.now() - self.rentDate).days)
